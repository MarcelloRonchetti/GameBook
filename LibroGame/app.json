{
  "expo": {
    "name": "LibroGame",
    "slug": "librogame",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/app-icons/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/app-icons/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.librogame.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icons/adaptive-icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "package": "com.librogame.app",
      "permissions": []
    },
    "web": {
      "favicon": "./assets/app-icons/favicon.png"
    },
    "plugins": [
      "./gradle-memory-plugin"
    ],
    "extra": {
      "eas": {
        "projectId": "bf9b86f3-59ad-4400-8249-9c26abcc7106"
      }
    }
  }
}
